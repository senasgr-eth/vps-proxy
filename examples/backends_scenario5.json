{
  "listen": "0.0.0.0:33330", // Global port for dynamic payload-based routing (scans for c=NENG, c=BTC, etc.)
  "tunnel_listen": "0.0.0.0:44444",
  "secret_token": "token_for_scenario_5",
  "tls_cert": "/etc/stratum-proxy/cert.pem",
  "tls_key": "/etc/stratum-proxy/key.pem",
  "default_group": "group_neng_dynamic",
  "failback_cooldown": "2h",
  "groups": [
    {
      "name": "group_neng_dynamic",
      "coins": ["NENG", "MTBC"],
      "static_mapping": false
    },
    {
      "name": "group_neng_low",
      "coins": ["NENG"],
      "listen": "0.0.0.0:33331", // VPS open port for low difficulty NENG
      "static_mapping": true
    },
    {
      "name": "group_neng_high",
      "coins": ["NENG"],
      "listen": "0.0.0.0:33332", // VPS open port for high difficulty NENG
      "static_mapping": true
    },
    {
      "name": "group_nxe_dedicated",
      "coins": ["NXE"],
      "listen": "0.0.0.0:33333", // VPS open port dedicated to NXE
      "static_mapping": true
    },
    {
      "name": "group_sha256_dynamic",
      "coins": ["BTC", "BCH"],
      "static_mapping": false
    },
    {
      "name": "group_doge_dedicated",
      "coins": ["DOGE"],
      "listen": "0.0.0.0:33334", // VPS open port dedicated to DOGE
      "static_mapping": true
    },
    {
      "name": "group_ltc_dedicated",
      "coins": ["LTC"],
      "listen": "0.0.0.0:33335", // VPS open port dedicated to LTC
      "static_mapping": true
    }
  ]
}
